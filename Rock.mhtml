@charset "utf-8";

* { text-align: center; align-items: center; margin: 0px; padding: 0px; }

div { margin: 0px; }

img { width: 100px; height: 100px; }

body, h1, html { margin: 0px; }

#orange { color: orange; }

#green { color: limegreen; }

.header { background-color: rgb(8, 27, 49); color: white; height: 5rem; lin=
e-height: 5rem; font-size: 1.3rem; }

.choices { display: flex; align-items: center; justify-content: center; }

p { text-align: center; margin-top: 0px; margin-bottom: 0px; }

.choice { border: 2px solid black; padding: 20px; border-radius: 50%; margi=
n: 1.5rem; transition-duration: 0.7s; }

.choice:hover { transform: scale(0.9); box-shadow: rgba(0, 0, 0, 0.5) 5px 5=
px 10px; }

.score-board { display: flex; align-items: center; justify-content: center;=
 font-size: 2rem; gap: 3rem; }

#user-score, #Comp-score { font-size: 3rem; }

.msg-container { margin-top: 3rem; }

#msg { background-color: rgb(8, 27, 49); color: white; display: inline; fon=
t-size: 2rem; padding: 1rem; border-radius: 1rem; }
